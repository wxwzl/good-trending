# 数据库配置
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/good_trending"

# Redis 配置
REDIS_URL="redis://localhost:6379"

# ============================================
# 应用端口 (本地开发固定端口)
# ============================================
# Web 前端 - http://localhost:3010
WEB_PORT=3010

# API 服务 - http://localhost:3015
API_PORT=3015

# 爬虫调试服务
CRAWLER_PORT=3016

# 调度器管理台
SCHEDULER_PORT=3017

# ============================================
# API 配置
# ============================================
# 服务端渲染时使用的 API 地址 (Docker 容器内访问主机)
API_URL=http://host.docker.internal:3015/api/v1

# 客户端使用的 API 地址
NEXT_PUBLIC_API_URL=http://localhost:3015/api/v1

CORS_ORIGINS=http://localhost:3010

# 爬虫配置 (可选)
# PROXY_URL="http://proxy:port"

# ============================================
# AI 智能分析配置
# ============================================
# 是否启用 AI 分析 (true/false)
ENABLE_AI_ANALYSIS=false

# AI 提供商 (kimi | bailian | zhipu)
AI_PROVIDER=kimi

# API Key (根据提供商填写对应的 Key)
AI_API_KEY=

# 模型名称 (可选，留空使用默认)
# AI_MODEL=kimi-k2.5

# API 基础 URL (可选，留空使用默认)
# AI_BASE_URL=https://api.moonshot.cn/v1

# 请求超时 (毫秒，默认 30000)
AI_TIMEOUT=30000

# 最大重试次数 (默认 3)
AI_MAX_RETRIES=3

# 每次分析的最大商品数 (默认 6)
AI_MAX_PRODUCTS=6

# ============================================
# 亚马逊搜索配置
# ============================================
# 每个关键词取前 N 个商品 (默认 6)
AMAZON_SEARCH_LIMIT=6

# 搜索间隔 (毫秒，默认 5000)
AMAZON_SEARCH_DELAY=5000

# 亚马逊域名 (默认 amazon.com)
AMAZON_DOMAIN=amazon.com
