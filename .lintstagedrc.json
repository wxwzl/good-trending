{
  "apps/api/**/*.ts": [
    "pnpm --filter @good-trending/api run lint:staged",
    "pnpm --filter @good-trending/api run format:staged"
  ],
  "apps/crawler/**/*.ts": [
    "pnpm --filter @good-trending/crawler run lint:staged",
    "pnpm --filter @good-trending/crawler run format:staged"
  ],
  "apps/scheduler/**/*.ts": [
    "pnpm --filter @good-trending/scheduler run lint:staged",
    "pnpm --filter @good-trending/scheduler run format:staged"
  ],
  "apps/web/**/*.{ts,tsx}": [
    "pnpm --filter @good-trending/web run lint:staged",
    "pnpm --filter @good-trending/web run format:staged"
  ],
  "apps/web/**/*.{css,scss}": ["pnpm --filter @good-trending/web run format:staged"],
  "packages/database/**/*.ts": [
    "pnpm --filter @good-trending/database run lint:staged",
    "pnpm --filter @good-trending/database run format:staged"
  ],
  "packages/shared/**/*.ts": [
    "pnpm --filter @good-trending/shared run lint:staged",
    "pnpm --filter @good-trending/shared run format:staged"
  ],
  "*.{json,md}": ["prettier --write"]
}
