{
  "name": "@good-trending/crawler",
  "version": "1.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./manager": "./src/manager.ts",
    "./crawlers/*": "./src/crawlers/*.ts"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development APP_ENV=development node scripts/run.js dev",
    "start": "cross-env NODE_ENV=production APP_ENV=production node scripts/run.js start",
    "build": "cross-env NODE_ENV=production APP_ENV=production node scripts/run.js build",
    "crawl:twitter": "tsx src/index.ts --source twitter",
    "crawl:amazon": "tsx src/index.ts --source amazon",
    "crawl:all": "tsx src/index.ts --source all",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:staged": "eslint --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:staged": "prettier --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@good-trending/database": "workspace:*",
    "@good-trending/shared": "workspace:*",
    "@paralleldrive/cuid2": "^2.2.2",
    "bullmq": "^5.1.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.44.2",
    "ioredis": "^5.3.2",
    "playwright": "^1.42.1",
    "winston": "^3.12.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.11.24",
    "@types/yargs": "^17.0.32",
    "cross-env": "^10.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "^3.4.2",
    "tsup": "^8.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^1.3.1"
  }
}
