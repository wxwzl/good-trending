{
  "name": "@good-trending/crawler",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup",
    "crawl:twitter": "tsx src/index.ts --source twitter",
    "crawl:amazon": "tsx src/index.ts --source amazon",
    "crawl:all": "tsx src/index.ts --source all",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@good-trending/database": "workspace:*",
    "@good-trending/shared": "workspace:*",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "playwright": "^1.42.1",
    "winston": "^3.12.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/yargs": "^17.0.32",
    "tsup": "^8.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
