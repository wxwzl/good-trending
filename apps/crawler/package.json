{
  "name": "@good-trending/crawler",
  "version": "1.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./index": "./src/index.ts",
    "./services": "./src/services/index.ts",
    "./crawlers/*": "./src/crawlers/*.ts"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development APP_ENV=development node scripts/run.js dev",
    "start": "cross-env NODE_ENV=production APP_ENV=production node scripts/run.js start",
    "build": "cross-env NODE_ENV=production APP_ENV=production node scripts/run.js build",
    "crawl:test": "tsx src/test-reddit-crawler.ts",
    "crawl:test-serpapi": "tsx src/test-serpapi.ts",
    "test:google-search": "tsx scripts/test-google-search.ts",
    "test:google-search:browser": "tsx scripts/test-google-search.ts --mode=browser --headed",
    "test:google-search:serpapi": "tsx scripts/test-google-search.ts --mode=serpapi",
    "test:google": "tsx scripts/quick-test-google.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:scripts": "eslint scripts --parser-options=project:tsconfig.scripts.json",
    "lint:staged": "eslint --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:scripts": "prettier --write \"scripts/**/*.ts\"",
    "format:staged": "prettier --write",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json"
  },
  "dependencies": {
    "@good-trending/database": "workspace:*",
    "@good-trending/shared": "workspace:*",
    "@paralleldrive/cuid2": "^3.3.0",
    "bullmq": "^5.71.0",
    "chalk": "^5.3.0",
    "crawlee": "^3.16.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.10.1",
    "playwright": "^1.42.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "serpapi": "^2.2.1",
    "winston": "^3.12.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.11.24",
    "@types/yargs": "^17.0.32",
    "cross-env": "^10.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "^3.4.2",
    "tsup": "^8.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^1.3.1"
  }
}
