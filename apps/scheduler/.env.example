# ============================================
# 调度器环境变量配置
# ============================================

# Redis 配置（BullMQ 队列）
REDIS_URL=redis://localhost:6379

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/good_trending

# AI 分析配置
ENABLE_AI_ANALYSIS=true
AI_PROVIDER=kimi
AI_API_KEY=your_api_key_here
AI_MODEL=kimi-k2-5

# ============================================
# 【新增】爬虫实现配置
# ============================================

# 全局爬虫实现类型
# 可选值: legacy | crawlee
# legacy: 使用现有 Playwright 实现（默认）
# crawlee: 使用新的 Crawlee 框架实现
CRAWLER_IMPLEMENTATION=legacy

# 各模块单独配置（覆盖全局配置）
# 如果不设置，则使用全局 CRAWLER_IMPLEMENTATION 配置
GOOGLE_SEARCH_IMPLEMENTATION=legacy
REDDIT_IMPLEMENTATION=legacy
AMAZON_SEARCH_IMPLEMENTATION=legacy

# 示例：使用 Crawlee 实现
# CRAWLER_IMPLEMENTATION=crawlee

# 示例：混合配置
# CRAWLER_IMPLEMENTATION=legacy
# GOOGLE_SEARCH_IMPLEMENTATION=crawlee
# REDDIT_IMPLEMENTATION=crawlee
