{
  "name": "@good-trending/scheduler",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development APP_ENV=development node scripts/run.js dev",
    "start": "cross-env NODE_ENV=production APP_ENV=production node scripts/run.js start",
    "build": "cross-env NODE_ENV=production APP_ENV=production node scripts/run.js build",
    "deploy:build": "cross-env NODE_ENV=production APP_ENV=production node scripts/deploy.cjs",
    "worker": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "lint:staged": "eslint --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:staged": "prettier --write",
    "typecheck": "tsc --noEmit",
    "backfill": "cross-env NODE_ENV=development APP_ENV=development tsx ./scripts/backfill-historical-data.ts",
    "backfill:prod": "cross-env NODE_ENV=production APP_ENV=production tsx ./scripts/backfill-historical-data.ts"
  },
  "dependencies": {
    "@good-trending/crawler": "workspace:*",
    "@good-trending/database": "workspace:*",
    "@good-trending/shared": "workspace:*",
    "@paralleldrive/cuid2": "^3.3.0",
    "bullmq": "^5.71.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.10.1",
    "node-cron": "^4.2.1",
    "winston": "^3.12.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.11.24",
    "@types/node-cron": "^3.0.11",
    "@types/yargs": "^17.0.32",
    "playwright": "^1.42.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "^3.4.2",
    "tsup": "^8.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^1.3.1"
  }
}
