{
  "name": "@good-trending/tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:web": "playwright test --project=web",
    "test:e2e:api": "playwright test --project=api",
    "test:api": "vitest run --config vitest.config.ts",
    "test:api:watch": "vitest --config vitest.config.ts",
    "test:api:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:all": "pnpm run test:api && pnpm run test:integration && pnpm run test:e2e",
    "playwright:install": "playwright install",
    "playwright:report": "playwright show-report"
  },
  "dependencies": {
    "@good-trending/shared": "workspace:*",
    "@good-trending/database": "workspace:*"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.42.1",
    "@types/node": "^20.11.24",
    "@vitest/coverage-v8": "^1.3.1",
    "dotenv": "^16.4.5",
    "msw": "^2.12.13",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
