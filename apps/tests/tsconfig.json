{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@good-trending/shared": ["../../packages/shared/src"],
      "@good-trending/database": ["../../packages/database/src"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*", "*.config.ts", "*.setup.ts"],
  "exclude": ["node_modules", "dist", "coverage", "test-results", "playwright-report"]
}
