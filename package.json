{
  "name": "good-trending",
  "version": "1.0.0",
  "private": true,
  "description": "商品趋势追踪平台 - 发现 reddit 平台和亚马逊的热门商品趋势",
  "scripts": {
    "dev:api": "pnpm --filter @good-trending/api dev",
    "dev:web": "pnpm --filter @good-trending/web dev",
    "dev:scheduler": "pnpm --filter @good-trending/scheduler dev",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "deploy:build": "turbo run deploy:build --filter=@good-trending/api --filter=@good-trending/web --filter=@good-trending/scheduler  --filter=@good-trending/database",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "test": "turbo run test",
    "test:unit": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "test:api": "pnpm --filter @good-trending/tests test:api",
    "test:e2e": "pnpm --filter @good-trending/tests test:e2e",
    "test:all": "pnpm run test:api && pnpm run test:e2e",
    "test:affected": "node scripts/detect-changes.cjs",
    "db:generate": "pnpm --filter @good-trending/database db:generate",
    "db:push:dev": "pnpm --filter @good-trending/database db:push:dev",
    "db:push": "pnpm --filter @good-trending/database db:push",
    "db:migrate": "pnpm --filter @good-trending/database db:migrate",
    "db:migrate:env": "pnpm --filter @good-trending/database db:migrate:env",
    "db:migrate:dev": "cross-env NODE_ENV=development pnpm --filter @good-trending/database db:migrate:env",
    "db:migrate:test": "cross-env NODE_ENV=test pnpm --filter @good-trending/database db:migrate:env",
    "db:migrate:prod": "cross-env NODE_ENV=production pnpm --filter @good-trending/database db:migrate:env",
    "db:studio": "pnpm --filter @good-trending/database db:studio",
    "db:seed:dev": "pnpm --filter @good-trending/database db:seed:dev",
    "db:seed:categories:dev": "pnpm --filter @good-trending/database db:seed:categories:dev",
    "db:seed:categories": "pnpm --filter @good-trending/database db:seed:categories",
    "db:reset": "pnpm --filter @good-trending/database db:reset",
    "db:cleanup": "pnpm --filter @good-trending/database db:cleanup",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "crawl": "pnpm --filter @good-trending/crawler crawl:all",
    "crawl:twitter": "pnpm --filter @good-trending/crawler crawl:twitter",
    "crawl:amazon": "pnpm --filter @good-trending/crawler crawl:amazon",
    "scheduler": "pnpm --filter @good-trending/scheduler start",
    "prepare": "husky",
    "commit": "cz",
    "deploy:pack": "node ./scripts/deploy.cjs pack",
    "build:tar": "pnpm run deploy:build && pnpm run deploy:pack"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cz-customizable": "^7.5.1",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.2.0",
    "ssh2-sftp-client": "^11.0.0",
    "tar": "^7.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": ".cz-config.js"
    }
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
