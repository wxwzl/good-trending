{
  "name": "@good-trending/database",
  "version": "1.0.0",
  "private": true,
  "description": "Database schema and client for Good-Trending",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./schema": {
      "require": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "cross-env NODE_ENV=development APP_ENV=development node scripts/run.js dev",
    "db:generate": "drizzle-kit generate",
    "db:push:dev": "cross-env NODE_ENV=development APP_ENV=development tsx ./scripts/db-push.ts && pnpm run db:seed:categories:dev",
    "db:push": "cross-env NODE_ENV=production APP_ENV=production tsx ./scripts/db-push.ts && pnpm run db:seed:categories",
    "db:migrate": "cross-env NODE_ENV=development APP_ENV=production node scripts/migrate.cjs",
    "db:migrate:dev": "cross-env NODE_ENV=development APP_ENV=development node scripts/migrate.cjs",
    "db:studio": "drizzle-kit studio",
    "deploy:build": "cross-env NODE_ENV=production APP_ENV=production node scripts/deploy.cjs",
    "db:seed:dev": "tsx src/seed.ts",
    "db:seed:categories:dev": "cross-env NODE_ENV=development APP_ENV=development tsx ./scripts/seed-categories.ts",
    "db:seed:categories": "cross-env NODE_ENV=development APP_ENV=production tsx ./scripts/seed-categories.ts",
    "db:reset": "tsx src/scripts/reset-database.ts",
    "db:cleanup": "tsx src/scripts/cleanup-data.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:staged": "eslint --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:staged": "prettier --write",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@good-trending/shared": "workspace:*",
    "@paralleldrive/cuid2": "^2.2.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.44.2",
    "ioredis": "^5.3.2",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.13.5",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "^3.4.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
