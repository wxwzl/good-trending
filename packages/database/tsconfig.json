{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/**/*",
    "scripts/check-crawler-logs.ts",
    "scripts/check-products.ts",
    "scripts/cleanup-data.ts",
    "scripts/db-push.ts",
    "scripts/reset-database.ts",
    "scripts/seed-categories.ts",
    "src/loadEnv.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
